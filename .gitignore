# ─────────────────────────────────────────────────────────────────────────────
# Echelix Playwright Automation - .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── Environment & Secrets ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local
credentials.json
token.json

# ── Node.js ───────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── TypeScript Build Output ───────────────────────────────────────────────────
dist/
build/
*.js.map

# ── Playwright Test Artifacts ─────────────────────────────────────────────────
playwright-report/
test-results/
.playwright/

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── VS Code ───────────────────────────────────────────────────────────────────
.vscode/settings.json
.vscode/launch.json
.vscode/*.code-workspace

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
